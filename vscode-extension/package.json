{
  "name": "coders-bible",
  "displayName": "The Coder's Bible",
  "description": "Sovereign offline developer knowledge engine — search 67K+ fragments, analyze code, all without leaving VS Code. Zero AI. Zero network.",
  "version": "2.1.0",
  "publisher": "VrtxOmega",
  "repository": {
    "type": "git",
    "url": "https://github.com/VrtxOmega/the-coders-bible"
  },
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codersBible",
          "title": "The Coder's Bible",
          "icon": "media/omega.svg"
        }
      ]
    },
    "views": {
      "codersBible": [
        {
          "type": "webview",
          "id": "codersBible.sidebar",
          "name": "The Coder's Bible",
          "icon": "media/omega.svg",
          "contextualTitle": "The Coder's Bible"
        }
      ]
    },
    "commands": [
      {
        "command": "codersBible.search",
        "title": "Coder's Bible: Search",
        "icon": "$(search)"
      },
      {
        "command": "codersBible.analyze",
        "title": "Coder's Bible: Analyze Selection",
        "icon": "$(microscope)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codersBible.analyze",
          "when": "editorHasSelection",
          "group": "navigation@9"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codersBible.search",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      },
      {
        "command": "codersBible.analyze",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "The Coder's Bible",
      "properties": {
        "codersBible.dbPath": {
          "type": "string",
          "default": "",
          "description": "Path to coders_bible.db (auto-detected if blank)"
        },
        "codersBible.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable to use for cb.py (search/stats backend)"
        },
        "codersBible.binPath": {
          "type": "string",
          "default": "",
          "description": "Path to coders-bible-cli binary (used for Analyze; falls back to PATH if blank)"
        },
        "codersBible.defaultDomain": {
          "type": "string",
          "default": "",
          "description": "Filter to a default domain (e.g. python, javascript)"
        }
      }
    }
  }
}
